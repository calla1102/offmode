{
  "expo": {
    "name": "offmode",
    "slug": "offmode",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0d0d14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.minnnj.offmode",
      "appleTeamId": "F93MCV6G64",
      "usesAppleSignIn": true,
      "privacyPolicyUrl": "https://fuchsia-belief-040.notion.site/OFFMODE-34309a0b0e3e809b965bd62530627431"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0d0d14"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.minnnj.offmode"
    },
    "plugins": [
      "expo-asset",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#22c97a"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "offmode가 미션 인증을 위해 카메라에 접근합니다.",
          "microphonePermission": false
        }
      ],
      "expo-apple-authentication",
      [
        "@react-native-seoul/kakao-login",
        {
          "kakaoAppKey": "62ae912ced27c2b48181b0a6d1c84353"
        }
      ],
      "expo-secure-store",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "55f790bd-66d2-44f7-bacc-2d422434926b"
      }
    },
    "owner": "offmodelog"
  }
}
